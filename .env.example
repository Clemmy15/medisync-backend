APP_NAME=MedisyncAI
DEBUG=false
API_PREFIX=/api/v1
LOG_LEVEL=INFO
ENABLE_DOCS=false

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000,http://127.0.0.1:5500,http://localhost:5500

DATABASE_URL=postgresql+asyncpg://medisync:medisync@localhost:5432/medisync
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

SECRET_KEY=your-secret-key-here-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=1440

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_AUTH_PER_MINUTE=10

LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=medisync_memories

ADMIN_EMAIL=admin@medisync.ai
ADMIN_PASSWORD=admin123!
